# App DB connection (read by CodeIgniter via DB_* fallbacks)
DB_HOST=db
DB_PORT=3306
DB_NAME=dana
DB_USER=dana_user
DB_PASSWORD=change_me_in_production

# MySQL container initialization
MYSQL_DATABASE=dana
MYSQL_USER=dana_user
MYSQL_PASSWORD=change_me_in_production
MYSQL_ROOT_PASSWORD=change_root_password_too

# phpMyAdmin connection
PMA_HOST=db
PMA_USER=dana_user
PMA_PASSWORD=change_me_in_production
